// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id             Int            @id @default(autoincrement())
  employeeNumber Int            @unique
  fullName       String
  officialEmail  String         @unique
  password       String
  departmentId   Int
  designation    String
  joiningDate    DateTime
  status         EmployeeStatus @default(ACTIVE)
  role           RoleName       @default(EMPLOYEE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tokenVersion   Int            @default(0)

  department      Department?         @relation(fields: [departmentId], references: [id])
  allocations     AllocationHistory[] @relation("AssignedEmployee")
  allocatedBy     AllocationHistory[] @relation("AllocatedByAdmin")
  receivedReturns AllocationHistory[] @relation("ReceivingAdmin")
  createdTickets  Ticket[]            @relation("TicketCreator")
  assignedTickets Ticket[]            @relation("TicketAssignee")
  linkedTickets   Ticket[]            @relation("TicketLinkedEmployee")
  ticketComments  TicketComment[]
}

model Asset {
  id            Int           @id @default(autoincrement())
  assetCategory AssetCategory
  assetType     String
  assetName     String
  brandVendor   String?
  modelPlan     String?
  purchaseDate  DateTime?
  status        AssetStatus   @default(INVENTORY)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  allocations         AllocationHistory[]
  physicalAsset       PhysicalAsset?
  digitalSubscription DigitalSubscription?
  tickets             Ticket[]

  @@map("assets")
}

model PhysicalAsset {
  id           Int     @id @default(autoincrement())
  assetId      Int     @unique
  serialNumber String? @unique
  macAddress   String? @unique
  assetTag     String? @unique

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("physical_assets")
}

model DigitalSubscription {
  id              Int       @id @default(autoincrement())
  assetId         Int       @unique
  planLicenseType String?
  totalSeats      Int?
  renewalDate     DateTime?
  accountOwner    String?
  licenseKey      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@map("digital_subscriptions")
}

model AllocationHistory {
  id                 Int              @id @default(autoincrement())
  assetId            Int
  assignedEmployeeId Int
  allocationDate     DateTime
  allocatedById      Int?
  returnDate         DateTime?
  receivingAdminId   Int?
  returnCondition    ReturnCondition?
  remarks            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  asset            Asset     @relation(fields: [assetId], references: [id])
  assignedEmployee Employee  @relation("AssignedEmployee", fields: [assignedEmployeeId], references: [id])
  allocatedBy      Employee? @relation("AllocatedByAdmin", fields: [allocatedById], references: [id])
  receivingAdmin   Employee? @relation("ReceivingAdmin", fields: [receivingAdminId], references: [id])

  @@map("allocation_history")
}

model RolePermission {
  role       RoleName
  permission Permission

  @@id([role, permission])
}

model Ticket {
  id               Int            @id @default(autoincrement())
  title            String
  description      String
  category         TicketCategory
  priority         TicketPriority @default(MEDIUM)
  status           TicketStatus   @default(OPEN)
  creatorId        Int
  assigneeId       Int?
  linkedEmployeeId Int?
  linkedAssetId    Int?
  attachments      String[]
  resolutionNote   String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  creator        Employee        @relation("TicketCreator", fields: [creatorId], references: [id])
  assignee       Employee?       @relation("TicketAssignee", fields: [assigneeId], references: [id])
  linkedEmployee Employee?       @relation("TicketLinkedEmployee", fields: [linkedEmployeeId], references: [id])
  linkedAsset    Asset?          @relation(fields: [linkedAssetId], references: [id])
  comments       TicketComment[]

  @@map("tickets")
}

model TicketComment {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  updaterId Int
  comment   String
  createdAt DateTime @default(now())

  ticket  Ticket   @relation(fields: [ticketId], references: [id])
  updater Employee @relation(fields: [updaterId], references: [id])

  @@map("ticket_comments")
}

model Department {
  id   Int    @id @default(autoincrement())
  name String @unique

  employees Employee[]
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  EXITED
}

enum RoleName {
  EMPLOYEE
  ADMIN
  SUPER_ADMIN
}

enum Permission {
  EMPLOYEE_CREATE
  EMPLOYEE_READ
  EMPLOYEE_UPDATE
  EMPLOYEE_DELETE

  ASSET_CREATE
  ASSET_READ
  ASSET_UPDATE
  ASSET_DELETE

  ALLOCATION_CREATE
  ALLOCATION_READ
  ALLOCATION_UPDATE

  TICKET_READ
  TICKET_MANAGE
  TICKET_DELETE
}

enum AssetStatus {
  INVENTORY
  ALLOCATED
  UNDER_MAINTENANCE
  RETURNED
  INACTIVE
  LOST
  RETIRED
}

enum AssetCategory {
  HARDWARE
  ACCESSORY
  SOFTWARE
  AI_SUBSCRIPTION
  SAAS_TOOL
  OTHER
}

enum ReturnCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
}

enum TicketCategory {
  HARDWARE_ISSUE
  SOFTWARE_ISSUE
  ACCESS_ISSUE
  ASSET_REQUEST
  SUBSCRIPTION_ISSUE
  GENERAL_SUPPORT
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_USER
  RESOLVED
  CLOSED
  REOPENED
}
