// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id             Int            @id @default(autoincrement())
  employeeNumber Int            @unique
  fullName       String
  officialEmail  String         @unique
  password       String
  department     String
  designation    String
  joiningDate    DateTime
  status         EmployeeStatus @default(ACTIVE)
  role           RoleName       @default(EMPLOYEE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  allocations     AllocationHistory[] @relation("AssignedEmployee")
  allocatedBy     AllocationHistory[] @relation("AllocatedByAdmin")
  receivedReturns AllocationHistory[] @relation("ReceivingAdmin")
}

model Asset {
  id            Int           @id @default(autoincrement())
  assetCategory AssetCategory
  assetType     String
  assetName     String
  brandVendor   String?
  modelPlan     String?
  purchaseDate  DateTime?
  status        AssetStatus   @default(INVENTORY)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  allocations         AllocationHistory[]
  physicalAsset       PhysicalAsset?
  digitalSubscription DigitalSubscription?

  @@map("assets")
}

model PhysicalAsset {
  id           Int     @id @default(autoincrement())
  assetId      Int     @unique
  serialNumber String? @unique
  macAddress   String? @unique
  assetTag     String? @unique

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("physical_assets")
}

model DigitalSubscription {
  id              Int       @id @default(autoincrement())
  assetId         Int       @unique
  planLicenseType String?
  totalSeats      Int?
  renewalDate     DateTime?
  accountOwner    String?
  licenseKey      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@map("digital_subscriptions")
}

model AllocationHistory {
  id                 Int              @id @default(autoincrement())
  assetId            Int
  assignedEmployeeId Int
  allocationDate     DateTime
  allocatedById      Int?
  returnDate         DateTime?
  receivingAdminId   Int?
  returnCondition    ReturnCondition?
  remarks            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  asset            Asset     @relation(fields: [assetId], references: [id])
  assignedEmployee Employee  @relation("AssignedEmployee", fields: [assignedEmployeeId], references: [id])
  allocatedBy      Employee? @relation("AllocatedByAdmin", fields: [allocatedById], references: [id])
  receivingAdmin   Employee? @relation("ReceivingAdmin", fields: [receivingAdminId], references: [id])

  @@map("allocation_history")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  EXITED
}

enum RoleName {
  EMPLOYEE
  ADMIN
  SUPER_ADMIN
}

enum AssetStatus {
  INVENTORY
  ALLOCATED
  UNDER_MAINTENANCE
  RETURNED
  INACTIVE
  LOST
  RETIRED
}

enum AssetCategory {
  HARDWARE
  ACCESSORY
  SOFTWARE
  AI_SUBSCRIPTION
  SAAS_TOOL
  OTHER
}

enum ReturnCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
}
